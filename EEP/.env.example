# Copiar a .env y ajustar valores
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Agente 1 - Pronóstico
FORECAST_HORIZON_DAYS=14
